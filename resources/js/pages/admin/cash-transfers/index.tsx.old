import { Head, usePage, router } from "@inertiajs/react";
import { useState, useEffect } from "react";
import AppLayout from "@/layouts/app-layout";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import { Textarea } from "@/components/ui/textarea";
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from "@/components/ui/select";
import { Spinner } from "@/components/ui/spinner";
import InputError from "@/components/input-error";
import {
  cashTransfersApi,
  cashSessionsApi,
  cashRegistersApi,
  type CashRegisterSession,
  type CashRegister,
} from "@/lib/api";
import type { SharedData } from "@/types";
import { hasPermission, isSuperAdmin } from "@/lib/permissions";
import { ArrowRightLeft } from "lucide-react";

export default function CashTransfersIndex() {
  const { auth } = usePage<SharedData>().props;
  const user = auth.user;
  const userIsSuperAdmin = isSuperAdmin(user);
  const canCreate = hasPermission('cash-transfers.create', user);

  const [sessions, setSessions] = useState<CashRegisterSession[]>([]);
  const [cashRegisters, setCashRegisters] = useState<CashRegister[]>([]);
  const [loading, setLoading] = useState(true);
  const [formLoading, setFormLoading] = useState(false);
  const [formData, setFormData] = useState({
    from_session_id: '',
    to_session_id: '',
    to_cash_register_id: '',
    amount: '',
    notes: '',
  });
  const [errors, setErrors] = useState<Record<string, string>>({});
  const [generalError, setGeneralError] = useState<string>('');

  useEffect(() => {
    if (!canCreate) {
      window.location.href = '/admin/dashboard';
      return;
    }
    loadData();
  }, [canCreate]);

  if (!canCreate) {
    return null;
  }

  const loadData = async () => {
    try {
      setLoading(true);
      const [sessionsData, registersData] = await Promise.all([
        cashSessionsApi.getAll({ status: 'open' }),
        cashRegistersApi.getAll(),
      ]);
      setSessions(sessionsData);
      setCashRegisters(registersData);
    } catch (error: any) {
      console.error('Error loading data:', error);
      setGeneralError(error.message || 'Error al cargar datos');
    } finally {
      setLoading(false);
    }
  };

  const handleSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    setErrors({});
    setGeneralError('');
    setFormLoading(true);

    try {
      const data: any = {
        from_session_id: parseInt(formData.from_session_id),
        amount: parseFloat(formData.amount),
        notes: formData.notes || undefined,
      };

      if (formData.to_session_id) {
        data.to_session_id = parseInt(formData.to_session_id);
      } else if (formData.to_cash_register_id) {
        data.to_cash_register_id = parseInt(formData.to_cash_register_id);
      }

      await cashTransfersApi.create(data);

      // Redirect to history page after successful creation
      router.visit('/admin/cash-transfers-history');
    } catch (error: any) {
      console.error('Error saving transfer:', error);
      if (error.errors) {
        const formattedErrors: Record<string, string> = {};
        Object.keys(error.errors).forEach(key => {
          formattedErrors[key] = Array.isArray(error.errors[key])
            ? error.errors[key][0]
            : error.errors[key];
        });
        setErrors(formattedErrors);
      } else {
        setGeneralError(error.message || 'Error al guardar transferencia');
      }
    } finally {
      setFormLoading(false);
    }
  };

  const resetForm = () => {
    setFormData({
      from_session_id: '',
      to_session_id: '',
      to_cash_register_id: '',
      amount: '',
      notes: '',
    });
    setErrors({});
    setGeneralError('');
  };

  return (
    <AppLayout title="Nueva Transferencia">
      <Head title="Nueva Transferencia" />
      <div className="space-y-6">
        <div className="flex justify-between items-center">
          <div>
            <h2 className="text-2xl font-bold tracking-tight">Nueva Transferencia</h2>
            <p className="text-muted-foreground">Registra una nueva transferencia entre cajas registradoras</p>
          </div>
          <Button
            variant="outline"
            onClick={() => router.visit('/admin/cash-transfers-history')}
          >
            Ver Historial
          </Button>
        </div>

        {generalError && (
          <div className="rounded-md bg-red-50 p-4 text-sm text-red-800 border border-red-200">
            {generalError}
          </div>
        )}

        {loading ? (
          <Card>
            <CardContent className="pt-6">
              <div className="flex items-center justify-center py-8">
                <Spinner className="mr-2" />
                <p>Cargando...</p>
              </div>
            </CardContent>
          </Card>
        ) : (
          <Card>
            <CardHeader>
              <CardTitle className="flex items-center gap-2">
                <ArrowRightLeft className="h-5 w-5" />
                Datos de la Transferencia
              </CardTitle>
              <CardDescription>
                Completa los datos para registrar la transferencia entre cajas
              </CardDescription>
            </CardHeader>
            <CardContent>
              <form onSubmit={handleSubmit} className="space-y-6">
                <div className="grid gap-6 md:grid-cols-2">
                  <div>
                    <Label htmlFor="from_session_id">Desde Sesión *</Label>
                    <Select
                      value={formData.from_session_id}
                      onValueChange={(value) => setFormData({ ...formData, from_session_id: value })}
                      disabled={formLoading}
                    >
                      <SelectTrigger>
                        <SelectValue placeholder="Selecciona la sesión origen" />
                      </SelectTrigger>
                      <SelectContent>
                        {sessions.map((session) => (
                          <SelectItem key={session.id} value={session.id.toString()}>
                            {session.session_number} - {session.cash_register?.name}
                          </SelectItem>
                        ))}
                      </SelectContent>
                    </Select>
                    <InputError message={errors.from_session_id} />
                  </div>

                  <div>
                    <Label htmlFor="amount">Monto *</Label>
                    <Input
                      id="amount"
                      type="number"
                      step="0.01"
                      min="0"
                      value={formData.amount}
                      onChange={(e) => setFormData({ ...formData, amount: e.target.value })}
                      required
                      disabled={formLoading}
                      placeholder="0.00"
                    />
                    <InputError message={errors.amount} />
                  </div>
                </div>

                <div className="space-y-4">
                  <div className="border-t pt-4">
                    <h3 className="font-medium mb-4">Destino de la Transferencia</h3>
                    <p className="text-sm text-muted-foreground mb-4">
                      Selecciona una sesión abierta o una caja registradora como destino
                    </p>

                    <div className="grid gap-6 md:grid-cols-2">
                      <div>
                        <Label htmlFor="to_session_id">Hacia Sesión</Label>
                        <Select
                          value={formData.to_session_id}
                          onValueChange={(value) => {
                            setFormData({ ...formData, to_session_id: value, to_cash_register_id: '' });
                          }}
                          disabled={formLoading || !!formData.to_cash_register_id}
                        >
                          <SelectTrigger>
                            <SelectValue placeholder="Selecciona la sesión destino (opcional)" />
                          </SelectTrigger>
                          <SelectContent>
                            <SelectItem value="">Sin sesión destino</SelectItem>
                            {sessions.map((session) => (
                              <SelectItem key={session.id} value={session.id.toString()}>
                                {session.session_number} - {session.cash_register?.name}
                              </SelectItem>
                            ))}
                          </SelectContent>
                        </Select>
                        <InputError message={errors.to_session_id} />
                      </div>

                      <div>
                        <Label htmlFor="to_cash_register_id">O Hacia Caja</Label>
                        <Select
                          value={formData.to_cash_register_id}
                          onValueChange={(value) => {
                            setFormData({ ...formData, to_cash_register_id: value, to_session_id: '' });
                          }}
                          disabled={formLoading || !!formData.to_session_id}
                        >
                          <SelectTrigger>
                            <SelectValue placeholder="Selecciona la caja destino (opcional)" />
                          </SelectTrigger>
                          <SelectContent>
                            <SelectItem value="">Sin caja destino</SelectItem>
                            {cashRegisters.filter(cr => cr.is_active).map((register) => (
                              <SelectItem key={register.id} value={register.id.toString()}>
                                {register.name}
                              </SelectItem>
                            ))}
                          </SelectContent>
                        </Select>
                        <InputError message={errors.to_cash_register_id} />
                      </div>
                    </div>
                  </div>

                  <div>
                    <Label htmlFor="notes">Notas</Label>
                    <Textarea
                      id="notes"
                      value={formData.notes}
                      onChange={(e) => setFormData({ ...formData, notes: e.target.value })}
                      disabled={formLoading}
                      rows={4}
                      placeholder="Observaciones o comentarios adicionales sobre la transferencia..."
                    />
                    <InputError message={errors.notes} />
                  </div>
                </div>

                <div className="flex justify-end space-x-4 pt-4 border-t">
                  <Button
                    type="button"
                    variant="outline"
                    onClick={resetForm}
                    disabled={formLoading}
                  >
                    Limpiar Formulario
                  </Button>
                  <Button type="submit" disabled={formLoading}>
                    {formLoading && <Spinner className="mr-2" size="sm" />}
                    Registrar Transferencia
                  </Button>
                </div>
              </form>
            </CardContent>
          </Card>
        )}
      </div>
    </AppLayout>
  );
}
